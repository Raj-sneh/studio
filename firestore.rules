rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PRODUCTION SECURITY RULES - ACTIVE
     * This ruleset implements a strict user-ownership model with administrative overrides.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user has an administrative record or is the developer. */
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'snehkumarverma2011@gmail.com'
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow list, delete: if isAdmin();
      
      // Allow admin to see subcollections
      match /{allSubcollections=**} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Collection Group access for Admin Activity Monitoring.
     */
    match /{path=**}/generatedMelodies/{melodyId} {
      allow read, list: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}