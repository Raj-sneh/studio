rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PRODUCTION SECURITY RULES - ACTIVE
     * This ruleset implements a strict user-ownership model.
     * All client access expiration issues are resolved by this permanent configuration.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has an administrative record. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow list, delete: if isAdmin();
    }

    /**
     * @description History of generated melodies or songs.
     */
    match /users/{userId}/generatedMelodies/{generatedMelodyId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    /**
     * @description User's saved neural clones.
     */
    match /users/{userId}/clonedVoices/{voiceId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    /**
     * @description Publicly available music lessons.
     */
    match /lessons/{lessonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description History of AI Teacher practice sessions.
     */
    match /users/{userId}/teacherSessions/{teacherSessionId} {
      allow get, list, create: if isOwner(userId);
      allow update, delete: if isOwner(userId);
    }

    /**
     * @description User-submitted reports for moderation.
     */
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow get, list, update, delete: if isAdmin();
    }

    /**
     * @description Control collection for administrative roles.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}