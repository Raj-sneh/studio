rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset implements a strict user-ownership model combined with administrative overrides.
     * Most user-generated content is stored in user-specific subcollections, ensuring that 
     * authorization is naturally aligned with the database structure.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    /** @description Checks if the authenticated user matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user is the owner and the document exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user has an administrative record in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow a user to check for their own document's existence and to read it.
      allow get: if isOwner(userId);

      // Allow a user to create their own document.
      allow create: if isOwner(userId);

      // Allow a user to update their own document after it has been created.
      allow update: if isExistingOwner(userId);

      // Only admins can list all users or delete a user's document.
      allow list, delete: if isAdmin();
    }

    /**
     * @description History of generated melodies or songs.
     */
    match /users/{userId}/generatedMelodies/{generatedMelodyId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description User's saved neural clones.
     */
    match /users/{userId}/clonedVoices/{voiceId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Publicly available music lessons.
     */
    match /lessons/{lessonId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description History of AI Teacher practice sessions.
     */
    match /users/{userId}/teacherSessions/{teacherSessionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description User-submitted reports for moderation.
     */
    match /reports/{reportId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.reporterId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    /**
     * @description Control collection for administrative roles.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
