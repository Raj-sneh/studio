
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "displayName",
        "email",
        "createdAt"
      ]
    },
    "ClonedVoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ClonedVoice",
      "type": "object",
      "description": "A neural voice clone saved by the user.",
      "properties": {
        "id": { "type": "string" },
        "voiceId": { "type": "string", "description": "The ElevenLabs Voice ID." },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "stability": { "type": "number" },
        "similarity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["voiceId", "name", "createdAt"]
    },
    "GeneratedMelody": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GeneratedMelody",
      "type": "object",
      "description": "Stores a historical record of melodies or songs generated by a user.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "instrument": { "type": "string" },
        "generationContext": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "instrument", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/clonedVoices/{voiceId}",
        "definition": {
          "entityName": "ClonedVoice",
          "schema": { "$ref": "#/backend/entities/ClonedVoice" },
          "description": "User's saved neural clones."
        }
      }
    ]
  }
}
