{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the account was created.",
          "format": "date-time"
        },
        "fcmToken": {
          "type": "string",
          "description": "FCM token for notifications (optional)."
        },
        "age": {
          "type": "number",
          "description": "The user's age."
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female", "other", "prefer-not-to-say"]
        },
        "dob": {
          "type": "object",
          "description": "Firestore Timestamp for DOB"
        }
      },
      "required": [
        "id",
        "displayName",
        "email",
        "createdAt"
      ]
    },
    "Lesson": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Lesson",
      "type": "object",
      "description": "Defines a music lesson available in the app.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "instrument": {
          "type": "string"
        },
        "tempo": {
          "type": "number"
        },
        "difficulty": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "required": [
        "id",
        "title",
        "instrument",
        "notes"
      ]
    },
    "GeneratedMelody": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GeneratedMelody",
      "type": "object",
      "description": "Stores a historical record of melodies or songs generated by a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instrument": {
          "type": "string"
        },
        "generationContext": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "userId",
        "title",
        "instrument",
        "createdAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google",
      "phone"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Individual user profiles."
        }
      },
      {
        "path": "/users/{userId}/generatedMelodies/{generatedMelodyId}",
        "definition": {
          "entityName": "GeneratedMelody",
          "schema": {
            "$ref": "#/backend/entities/GeneratedMelody"
          },
          "description": "User's history of generated melodies."
        }
      }
    ]
  }
}
